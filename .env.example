# Supabase — powers Google sign-in. Copy this file to `.env.local` and fill in
# the values from your Supabase project (Project Settings → API). Both are
# public/publishable values; the anon key is meant to ship in the browser.
#
# Vite only exposes vars prefixed with VITE_ to the client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
