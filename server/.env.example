# Pi Remote Server configuration. Copy to `.env` and fill in.
# Loaded via a fail-fast schema (src/config.ts) — the process refuses to start
# if a required value is missing or malformed.

# Port the HTTP + WebSocket server listens on (cloudflared forwards to it).
PORT=8787

# Supabase Postgres connection string (service-role access; ownership is
# enforced in code per spec §5.3/§6). Required for migrations and runtime.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Browser origin allowed on /client + the device/ticket endpoints (spec §7).
# Also used as the base for the device verification_uri (the SPA /device page).
ALLOWED_ORIGIN=https://pi-rimokon.vercel.app

# Issuer (`iss`) for agent JWTs; the public origin agents/clients reach.
JWT_ISSUER=https://agents.jlnshen.com

# RS256 signing keypair for agent tokens (spec §3.2). PEM strings — keep the
# private key secret (env only, never in the repo). Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -in priv.pem -pubout -out pub.pem
# In a .env file, wrap multi-line PEMs in double quotes with literal \n, e.g.
#   AGENT_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
AGENT_JWT_PRIVATE_KEY=
AGENT_JWT_PUBLIC_KEY=

# Supabase project URL — device approval verifies the user's Supabase JWT
# against this project's JWKS (spec §3.1).
SUPABASE_URL=https://your-project-ref.supabase.co

# Limits / hardening (spec §7) — optional; defaults shown.
# MAX_SESSIONS_PER_USER=20   # concurrent agent sessions per user (over → close 1013)
# MAX_CLIENTS_PER_USER=10    # concurrent browser clients per user (over → close 1013)
# WS_RATE_MAX=120            # inbound frames per window per connection (over → close 1008)
# WS_RATE_WINDOW_MS=1000     # rate-limit window
