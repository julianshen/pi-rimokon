# Pi Remote Server configuration. Copy to `.env` and fill in.
# Loaded via a fail-fast schema (src/config.ts) — the process refuses to start
# if a required value is missing or malformed.

# Port the HTTP + WebSocket server listens on (cloudflared forwards to it).
PORT=8787

# Supabase Postgres connection string (service-role access; ownership is
# enforced in code per spec §5.3/§6). Required for migrations and runtime.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Browser origin allowed on /client and the device/ticket endpoints (spec §7).
# e.g. https://pi-rimokon.vercel.app — optional until /client lands (M3).
# ALLOWED_ORIGIN=https://pi-rimokon.vercel.app
