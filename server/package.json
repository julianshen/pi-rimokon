{
  "name": "pi-remote-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pi Remote Server — standalone WebSocket /agent + /client endpoint with RFC 8628 device-flow auth",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/runMigrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.9",
    "supertest": "^7.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
